<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dai.mapper.ContactMapper">

    <resultMap id="ContactPageResDTOMap" type="com.dai.model.dto.response.ContactPageResDTO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="idCard" column="id_card"/>
        <result property="phone" column="phone"/>
        <result property="passengerType" column="passenger_type"/>
        <result property="isDefault" column="is_default"/>
        <result property="status" column="status"/>
    </resultMap>

    <resultMap id="ContactDetailResDTOMap" type="com.dai.model.dto.response.ContactDetailResDTO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="idCard" column="id_card"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="passengerType" column="passenger_type"/>
        <result property="isDefault" column="is_default"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <insert id="addContact">
        insert into contact (user_id, name, id_card, phone, email, passenger_type, is_default, remark)
        values (#{userId}, #{name}, #{idCard}, #{phone}, #{email}, #{passengerType}, #{isDefault}, #{remark})
    </insert>

    <select id="queryContacts" resultMap="ContactPageResDTOMap">
        select id,
        name,
        id_card,
        phone,
        passenger_type,
        is_default,
        status
        from contact
        where user_id = #{userId}
        <if test="name != null and name != ''">
            and name like concat('%', #{name}, '%')
        </if>
        <if test="passengerType != null">
            and passenger_type = #{passengerType}
        </if>
        <if test="status != null">
            and status = #{status}
        </if>
    </select>

    <select id="queryContactDetail" resultMap="ContactDetailResDTOMap">
        select id,
        name,
        id_card,
        phone,
        email,
        passenger_type,
        is_default,
        status,
        remark
        from contact
        where id = #{id}
    </select>

    <select id="getDefaultCount" resultType="java.lang.Integer">
        select count(id) from contact where user_id = #{userId} and is_default = 1
    </select>
</mapper>